# StashDB Stremio Addon - Configuration
# Copy this file to .env and fill in your values

# ===== REQUIRED =====
STASHDB_API_KEY=
PUBLIC_URL=http://localhost:7070
# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
SECRET_KEY=
PROWLARR_URL=
PROWLARR_API_KEY=

# ===== SERVER =====
PORT=7070

# ===== STASHDB =====
STASHDB_URL=https://stashdb.org/graphql
STASHDB_PER_PAGE=25
META_DESCRIPTION_MAX_LENGTH=1400
STASHDB_WEB_URL=https://stashdb.org

# ===== REAL-DEBRID =====
REALDEBRID_TIMEOUT_MS=15000
REALDEBRID_URL=https://api.real-debrid.com/rest/1.0

# ===== PROWLARR / SEARCH =====
PROWLARR_TIMEOUT_MS=30000
PROWLARR_MAX_REDIRECTS=5
PROWLARR_CATEGORIES=6000
# Max results Prowlarr returns per query (stream also sets this via `PROWLARR_LIMIT`)
PROWLARR_LIMIT=25

# Optional logging
PROWLARR_DEBUG=
PROWLARR_PARSED_LOG=

# ===== STREAM DISCOVERY (performance tuning) =====
# How long to reuse a cached candidates list (before re-querying Prowlarr)
CANDIDATE_CACHE_TTL_MS=21600000

# How many candidates we keep per scene (final output is also capped by STREAM_CANDIDATES_LIMIT)
DISCOVERY_STOP_AFTER_CANDIDATES=30

# Search batching / parallelism tuning
DISCOVERY_QUERY_VARIANTS=2
DISCOVERY_PREFILTER_CAP=90

# Only used if STREAM_QUERY_DELAY_AFTER_PARALLEL=1
DISCOVERY_QUERY_DELAY_MS=750
STREAM_QUERY_DELAY_AFTER_PARALLEL=

# Stream output tuning
STREAM_CANDIDATES_LIMIT=10
CANDIDATE_MIN_SCORE=400
DEBRID_CANDIDATES_RETURN_LIMIT=
STREAM_DEBUG=

# ===== RESOLVE (Real-Debrid on click) =====
RESOLVE_CACHE_TTL_MS=7200000

# ===== SCRAPER (optional background process) =====
SCRAPE_COUNT=100
SCRAPER_INTERVAL_MS=86400000
